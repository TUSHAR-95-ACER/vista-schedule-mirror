{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TG Master Journal",
  "version": "1.0.0",
  "identifier": "app.lovable.master-journal-tg",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "https://master-journal-tg.lovable.app",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TG Master Journal",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "url": "https://master-journal-tg.lovable.app"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "TG Master Journal desktop wrapper",
    "longDescription": "Native desktop window that loads the latest deployed TG Master Journal web application. Updates appear automatically with every Lovable deploy — no desktop rebuild required for normal UI changes."
  }
}
