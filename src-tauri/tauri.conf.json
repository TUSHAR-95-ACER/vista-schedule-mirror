{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TG Master Journal",
  "version": "1.0.0",
  "identifier": "app.lovable.master-journal-tg",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "https://master-journal-tg.lovable.app",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TG Master Journal",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "focus": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "url": "https://master-journal-tg.lovable.app"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app", "updater"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "Professional trading journal — desktop edition",
    "longDescription": "TG Master Journal desktop app: native window for the professional trading operating system. Auto-syncs with every web deploy and self-updates when a new native release ships.",
    "copyright": "© 2026 TG Master Journal",
    "publisher": "TG Master Journal",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": [
        "https://github.com/TG-MasterJournal/desktop-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
